# Copy this file to keystore.properties and fill in your real values.
# Never commit keystore.properties or your .jks/.keystore files.

# Absolute or relative path to your signing key file (.jks or .keystore)
storeFile=C:\\path\\to\\release-key.jks

# Keystore password
storePassword=your_keystore_password

# Key alias inside the keystore
keyAlias=your_key_alias

# Key password for the alias
keyPassword=your_key_password
